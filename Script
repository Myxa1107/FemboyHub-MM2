local playerData = {}
local playerDataReady = false

local function setupPlayerData()
	local remotes = game.ReplicatedStorage:FindFirstChild("Remotes")
	if remotes then
		local gameplay = remotes:FindFirstChild("Gameplay")
		if gameplay then
			local playerDataChanged = gameplay:FindFirstChild("PlayerDataChanged")
			if playerDataChanged then
				playerDataChanged.OnClientEvent:Connect(function(data)
					playerData = data
					playerDataReady = true
					RefreshAll()
				end)
				return true
			end
		end
	end
	return false
end

