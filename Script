local gunESP = {}

function CreateGunESP(obj)
	if not obj or obj.Name ~= "GunDrop" then return end
	if gunESP[obj] then return end
	local inside = false
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character and obj:IsDescendantOf(plr.Character) then inside = true break end
		if plr:FindFirstChild("Backpack") and obj:IsDescendantOf(plr.Backpack) then inside = true break end
	end
	if inside then return end
	local hl = Instance.new("Highlight")
	hl.Name = "GunDropHL"
	hl.FillColor = Color3.fromRGB(255, 255, 0)
	hl.FillTransparency = 0.3
	hl.OutlineTransparency = 0
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	hl.Adornee = obj
	hl.Parent = ESPFolder
	hl.Enabled = _G.ESP.ShowGunDrop()

	local bill = Instance.new("BillboardGui")
	bill.Name = "GunDropLabel"
	bill.Size = UDim2.new(0, 80, 0, 20)
	bill.StudsOffset = Vector3.new(0, 1.5, 0)
	bill.AlwaysOnTop = true
	bill.Adornee = obj
	bill.Parent = ESPFolder
	bill.Enabled = _G.ESP.ShowGunDrop()

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = "🔫 Gun"
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(255, 255, 0)
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.Parent = bill

	gunESP[obj] = {Highlight = hl, Billboard = bill}

	local role = GetRole(LocalPlayer)
	if _G.ESP.AutoGrabGun() and role ~= "Dead" then
		if not obj.Parent then return end
		local char = LocalPlayer.Character
		if not char then return end
		local oldPos = char:GetPivot()
		obj:PivotTo(oldPos)
		local backpack = LocalPlayer:FindFirstChild("Backpack")
		if backpack then backpack.ChildAdded:Wait() end
		obj:PivotTo(oldPos)
	end
end

local function RemoveGunESP(obj)
	if gunESP[obj] then
		if gunESP[obj].Highlight then gunESP[obj].Highlight:Destroy() end
		if gunESP[obj].Billboard then gunESP[obj].Billboard:Destroy() end
		gunESP[obj] = nil
		task.delay(0.5, function()
			RefreshAll()
		end)
	end
end

function RefreshGun()
