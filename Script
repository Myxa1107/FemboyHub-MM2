--  ФУНКЦИИ ПОИСКА РОЛЕЙ (ПРЯМО ИЗ YARHM)
-- ===================================================================
local function findMurderer()
	if playerDataReady then
		for playerName, data in playerData do
			if data.Role == "Murderer" then
				local player = game.Players:FindFirstChild(playerName)
				if player then return player end
			end
		end
	end

	-- Fallback: проверяем Backpack
	for _, i in ipairs(game.Players:GetPlayers()) do
		if i.Backpack:FindFirstChild("Knife") then
			return i
		end
	end

	-- Fallback: проверяем Character
	for _, i in ipairs(game.Players:GetPlayers()) do
		if not i.Character then continue end
		if i.Character:FindFirstChild("Knife") then
			return i
		end
	end

	return nil
end

local function findSheriff()
	if playerDataReady then
		for playerName, data in playerData do
			if data.Role == "Sheriff" then
				local player = game.Players:FindFirstChild(playerName)
				if player then return player end
			end
		end
	end

	-- Fallback: проверяем Backpack
	for _, i in ipairs(game.Players:GetPlayers()) do
		if i.Backpack:FindFirstChild("Gun") then
			return i
		end
	end

	-- Fallback: проверяем Character
	for _, i in ipairs(game.Players:GetPlayers()) do
		if not i.Character then continue end
		if i.Character:FindFirstChild("Gun") then
			return i
		end
	end

	return nil
end

-- ===================================================================
--  ОПРЕДЕЛЕНИЕ РОЛИ (БЕЗ ПРОВЕРКИ ЗДОРОВЬЯ, ТОЛЬКО РОЛЬ)
-- ===================================================================
local function GetRole(player)
	-- Если игрок есть в playerData с ролью, или имеет оружие – он в игре
	if playerDataReady then
		local playerName = player.Name
		if playerData[playerName] and playerData[playerName].Role then
			-- Определяем конкретную роль по данным
			if playerData[playerName].Role == "Murderer" then
				return "Murderer"
			elseif playerData[playerName].Role == "Sheriff" then
				return "Sheriff"
			elseif playerData[playerName].Role == "Innocent" then
				return "Innocent"
			end
		end
	end

	-- Если playerData ещё нет, используем fallback по оружию
	if player == findMurderer() then
		return "Murderer"
	elseif player == findSheriff() then
		return "Sheriff"
	else
		-- Если нет роли и нет оружия – считаем, что игрок не в игре
		return "Dead"
	end
end

local function GetColor(role)
	if role == "Murderer" then return Color3.fromRGB(255, 0, 0) end
	if role == "Sheriff"  then return Color3.fromRGB(0, 0, 255) end
	if role == "Innocent" then return Color3.fromRGB(0, 255, 0) end
	return Color3.fromRGB(128, 128, 128) -- Dead (не в игре)
end

