local function shootMurderer()

	local localplayer = game.Players.LocalPlayer

	if localplayer ~= findSheriff() then
		return
	end

	local murderer = findMurderer()
	if not murderer then
		return
	end

	-- Достаём пистолет
	local gun = localplayer.Character:FindFirstChild("Gun")
	if not gun then
		local backpack = localplayer:FindFirstChild("Backpack")
		if backpack then
			gun = backpack:FindFirstChild("Gun")
			if gun then
				local hum = localplayer.Character:FindFirstChild("Humanoid")
				if hum then
					hum:EquipTool(gun)
					task.wait(0.1)
				end
			end
		end
		if not gun then
			return
		end
	end

	local murdererHRP = murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart")
	if not murdererHRP then
		return
	end

	-- Берём настройки
	local offset = _G.ESP.ShootOffset()
	local pingMult = _G.ESP.ShootPingMult()

	local predictedPos = getPredictedPosition(murderer, offset, pingMult) or murdererHRP.Position

	local rightHand = localplayer.Character:FindFirstChild("RightHand")
	if not rightHand then
		return
	end

